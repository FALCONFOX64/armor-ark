# Basic .htaccess for Next.js static export on Apache/cPanel
# Secure and efficient serving of static files

Options -MultiViews
RewriteEngine On

# Security headers (basic)
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "SAMEORIGIN"
Header set X-XSS-Protection "1; mode=block"

# Serve index.html for directories or SPA-like routing if needed
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# Cache static assets aggressively
<FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Prevent access to sensitive files
<FilesMatch "^(\.env|\.git|node_modules|package\.json|yarn\.lock)">
    Order allow,deny
    Deny from all
</FilesMatch>